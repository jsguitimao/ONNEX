# =============================================================================
# Onnex VPS — copiar para /opt/onnex/.env no servidor e preencher.
# NUNCA commitar o ficheiro preenchido. chmod 600 /opt/onnex/.env
#
# Fonte dos valores: Vercel → Project → Settings → Environment Variables
# (são os MESMOS valores de produção, exceto a base de dados e POSTGRES_PASSWORD)
# =============================================================================

# --- Base de dados (Postgres no próprio VPS) ---------------------------------
# Password forte gerada uma vez (ex.: openssl rand -hex 24). Usada pelo container.
POSTGRES_PASSWORD=

# URL usada pela app e migrações DENTRO da rede Docker (host "db").
# Substituir <POSTGRES_PASSWORD> pelo valor acima. connection_limit=10 chega
# para um único servidor Node (não é serverless — o pool é partilhado).
DATABASE_URL_DOCKER=postgresql://onnex:<POSTGRES_PASSWORD>@db:5432/onnex?connection_limit=10

# --- URL pública --------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://onnex.pt

# --- Clerk (produção — copiar da Vercel) --------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Stripe (copiar da Vercel) -------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_TRIMESTRAL=
STRIPE_PRICE_ID_ANUAL=
STRIPE_WEBHOOK_SECRET=

# --- WhatsApp Cloud API (copiar da Vercel) -------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# --- Email (Resend — copiar da Vercel) -----------------------------------------
RESEND_API_KEY=
EMAIL_FROM=Onnex <reservas@onnex.pt>

# --- Rate-limit distribuído (Upstash — copiar da Vercel) -----------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Uploads (Vercel Blob continua a funcionar fora da Vercel) -----------------
BLOB_READ_WRITE_TOKEN=

# --- Cron de lembretes (copiar da Vercel) --------------------------------------
CRON_SECRET=

# --- Sentry (copiar da Vercel) --------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=production
