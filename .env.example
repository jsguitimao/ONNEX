# ===========================================
# Onnex — Environment variables
# ===========================================
# Copia este ficheiro para `.env` e preenche.
# Em produção (Vercel), define estas variáveis no dashboard do projeto.

# --- Base de dados (PostgreSQL) -----------------------------------------
# Recomendado: Neon (https://neon.tech) — plano free serve para dev/staging.
#
# PRODUÇÃO (serverless): DATABASE_URL TEM de usar connection pooling, senão o
# tráfego alto esgota o max_connections do Postgres. No Neon, copia a connection
# string do endpoint "Pooled connection" (host contém "-pooler"):
#   postgresql://USER:PASSWORD@ep-xxx-pooler.HOST/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# DIRECT_URL: ligação DIRETA (sem pooler), usada SÓ pelo Prisma CLI nas migrações
# (prisma migrate deploy / db push). No Neon é o endpoint "Direct connection"
# (host SEM "-pooler"). Em local podes repetir o valor de DATABASE_URL.
# Depois de definir esta var em TODOS os ambientes (local, CI e Vercel), adiciona
# a linha `directUrl = env("DIRECT_URL")` ao datasource em prisma/schema.prisma.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# --- Autenticação (Clerk) ------------------------------------------------
# Criar app em https://dashboard.clerk.com → API Keys.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"

# --- URL pública da aplicação -------------------------------------------
# Usada nos links dos emails (gerir reserva, página pública do negócio).
# Produção: https://www.onnex.pt (ou domínio próprio)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- WhatsApp transacional (Meta Cloud API) ------------------------------
# Número global Onnex (WhatsApp Business Platform / Meta for Developers).
# Templates aprovados obrigatórios. Se omitido, as mensagens são registadas
# como SKIPPED e a app continua a funcionar.
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_API_VERSION="v21.0"
# Webhook de estados de entrega (/api/webhooks/whatsapp):
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_APP_SECRET=""

# --- Pagamentos (Stripe) --------------------------------------------------
# Subscrição Pro com trial de 7 dias. Test mode em dev; live em produção.
STRIPE_SECRET_KEY=""
STRIPE_PRICE_ID=""
STRIPE_PRICE_ID_TRIMESTRAL=""
STRIPE_PRICE_ID_ANUAL=""
STRIPE_WEBHOOK_SECRET=""

# --- Cron de lembretes ----------------------------------------------------
# Segredo do endpoint /api/cron/send-reminders (chamado pelo cron-job.org).
CRON_SECRET=""

# --- Email transacional (Resend) ----------------------------------------
# https://resend.com → Domains → adicionar onnex.pt (verificar DNS) → API Keys.
# Usado para o email de confirmação de reserva. Se omitido, o email é registado
# como SKIPPED e a app continua a funcionar (WhatsApp + restante fluxo intactos).
# EMAIL_FROM tem de ser um endereço no domínio verificado (default: reservas@onnex.pt).
RESEND_API_KEY=""
EMAIL_FROM="Onnex <reservas@onnex.pt>"

# --- Rate-limit distribuído (Upstash Redis) -----------------------------
# Opcional mas recomendado em produção serverless. Sem estas vars, o rate-limit
# fica em memória (não partilha estado entre instâncias Vercel).
# Cria em https://console.upstash.com → Redis → Create database (REST).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Vercel Blob ---------------------------------------------------------
# Necessario para uploads em staging/producao.
BLOB_READ_WRITE_TOKEN=""
